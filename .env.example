# ── Database ────────────────────────────────────────────────
DB_NAME=wordpress
DB_USER=wp_user
DB_PASSWORD=CHANGE_ME_strong_password_here
DB_ROOT_PASSWORD=CHANGE_ME_root_password_here

# ── WordPress ────────────────────────────────────────────────
# Генерувати тут: https://api.wordpress.org/secret-key/1.1/salt/
# Формат: KEY=value (не PHP define()!). Значення з # $ пробілами — в лапках.
# Для Docker Compose: $ у значенні екрануй як $$ (наприклад foo$$bar → foo$bar у контейнері).
WP_AUTH_KEY=put-a-random-string-here
WP_SECURE_AUTH_KEY=put-a-random-string-here
WP_LOGGED_IN_KEY=put-a-random-string-here
WP_NONCE_KEY=put-a-random-string-here
WP_AUTH_SALT=put-a-random-string-here
WP_SECURE_AUTH_SALT=put-a-random-string-here
WP_LOGGED_IN_SALT=put-a-random-string-here
WP_NONCE_SALT=put-a-random-string-here

# ── Site ─────────────────────────────────────────────────────
WP_HOME=http://localhost
WP_SITEURL=http://localhost
WP_DEBUG=false
WP_TABLE_PREFIX=wp_